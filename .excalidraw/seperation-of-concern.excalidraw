      "link": null,
      "locked": false,
      "text": "An AI agent is an orchestrator of the components needed to complete a task using an LLM.\nIn simple terms, it coordinates the LLM, tools, memory, and workflows to achieve a goal.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "An AI agent is an orchestrator of the components needed to complete a task using an LLM.\nIn simple terms, it coordinates the LLM, tools, memory, and workflows to achieve a goal.",
      "autoResize": true,
      "lineHeight": 1.25
    },
